<odoo>
    <data>

         <record id="custom_invoice_paper_format" model="report.paperformat">
            <field name="name">A4</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">45</field>
            <field name="margin_bottom">30</field>
            <field name="margin_left">6</field>
            <field name="margin_right">6</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">40</field>
            <field name="dpi">90</field>
        </record>


        <record id="custom_invoice_reports" model="ir.actions.report">
            <field name="name">Invoice Report</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_invoice_v2.custom_invoice_report</field>
            <field name="report_file">custom_invoice_v2.custom_invoice_report</field>
            <field name="print_report_name">(object._get_report_base_filename())</field>
            <field name="attachment"/>
            <field name="paperformat_id" ref="custom_invoice_v2.custom_invoice_paper_format"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_type">report</field>
        </record>

        <record id="custom_invoice_reports_no_header" model="ir.actions.report">
            <field name="name">No Header Invoice</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">custom_invoice_v2.custom_invoice_report_no_header</field>
            <field name="report_file">custom_invoice_v2.custom_invoice_report_no_header</field>
            <field name="print_report_name">(object._get_report_base_filename())</field>
            <field name="attachment"/>
            <field name="paperformat_id" ref="custom_invoice_v2.custom_invoice_paper_format"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_type">report</field>
        </record>



    </data>
</odoo>