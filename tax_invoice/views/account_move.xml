<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>


        <record id="view_partner_inherit" model="ir.ui.view">
            <field name="name">res.partner.form</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group//group" position="inside">
                    <field name="additional_no"/>
                    <field name="cr_no"/>
                    <field name="custom_invoice" string="Tax Invoice"/>
                </xpath>
                <field name="name" position="after">
                    <field name="arabic_name" placeholder="Arabic Name"/>
                </field>
                <xpath expr="//div[@class='o_address_format']" position="after">
                    <label for="arabic_street" string="Arabic Address:"/>
                    <div>
                        <field name="arabic_street" placeholder="Arabic Street..."/>
                        <field name="arabic_street2" placeholder="Arabic Street 2..."/>
                        <div>
                            <field name="arabic_city" placeholder="Arabic City" style="width: 40%"/>
                        </div>
                    </div>
                </xpath>


            </field>
        </record>

        <record id="view_company_form_inherit" model="ir.ui.view">
            <field name="name">res.company.form</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group//group" position="inside">
                    <field name="additional_no"/>
                </xpath>
                <xpath expr="///h1" position="after">
                    <h3>
                        <field name="arabic_name" placeholder="Arabic Name" nolabel="1"/>
                    </h3>
                </xpath>
                <xpath expr="//field[@name='country_id']" position="after">
                    <label for="street" string="Arabic Address:"/>
                    <div>
                        <field name="arabic_street" placeholder="Arabic Street..."/>
                        <field name="arabic_street2"/>
                        <div>
                            <field name="arabic_city" placeholder="Arabic City" style="width: 40%%"/>
                        </div>
                    </div>
                </xpath>

            </field>
        </record>


    </data>
</odoo>

